# Configuración de la aplicación
NOMBRE_APP=API Gateway & Sentinel
VERSION=0.1.0
MODO_DEBUG=true
# Redis
REDIS_URL=redis://localhost:6379/0
# Rate limiting
LIMITE_PETICIONES=5
VENTANA_SEGUNDOS=60
# JWT (genero uno real: openssl rand -hex 32)
JWT_SECRETO=6848809334557581302635336381023540448316443150434045391332310316
JWT_ALGORITMO=HS256
JWT_EXPIRACION_MINUTOS=15

# Patrones de inyección (separados por coma, opcional)
# Si no se define, se usan los patrones por defecto del código
# PATRONES_INYECCION=select\s+.*from,union\s+select,drop\s+table
